code_templates = \{\
    "factorial": """def factorial(n):\
    if n == 0:\
        return 1\
    return n * factorial(n-1)""",\
    "fibonacci": """def fibonacci(n):\
    if n <= 1:\
        return n\
    return fibonacci(n-1) + fibonacci(n-2)""",\
    "hello world": """print("Hello, World!")""",\
    "miku_song": """def sing_miku_lyric(emotion='joy'):\
