# Build vocabulary (8-word limit initially)\
all_words = []\
tags = []\
for intent in intents['intents']:\
    tags.append(intent['tag'])\
    for pattern in intent['patterns']:\
        words = pattern.lower().split()\
        all_words.extend(words)\
for key in list(lore.keys()) + list(emotion_patterns.keys()):\
    all_words.extend(key.lower().split())\
all_words = sorted(set(all_words))[:8]  # Enforce 8-word limit\
\
# Prepare training data\
X = []\
y = []\
for i, intent in enumerate(intents['intents']):\
    patterns = intent['patterns'] + (list(lore.keys()) if intent['tag'] == 'lore_query' else [])\
    for pattern in patterns:\
        bag = np.zeros(len(all_words), dtype=np.float32)\
        words = pattern.lower().split()\
        for w in words:\
            if w in all_words:\
                bag[all_words.index(w)] = 1.0\
        X.append(bag)\
        y.append(i)\
\
X_train = np.array(X)\
y_train = np.array(y)\
\
# Neural network model\
class Aethyllumicora(nn.Module):\
    def __init__(self, input_size, hidden_size, output_size):\
        super(Aethyllumicora, self).__init__()\
        self.fc1 = nn.Linear(input_size, hidden_size)\
        self.fc2 = nn.Linear(hidden_size, hidden_size)\
        self.fc3 = nn.Linear(hidden_size, output_size)\
        self.relu = nn.ReLU()\
\
    def forward(self, x):\
        out = self.relu(self.fc1(x))\
        out = self.relu(self.fc2(out))\
        out = self.fc3(out)\
        return out\
\
# Initialize model\
input_size = len(all_words)\
hidden_size = 8\
output_size = len(tags)\
model = Aethyllumicora(input_size, hidden_size, output_size)\
\
# Load or train model\
MODEL_FILE = "aethyllumicora_model.pth"\
if os.path.exists(MODEL_FILE):\
    model.load_state_dict(torch.load(MODEL_FILE))\
else:\
    criterion = nn.CrossEntropyLoss()\
    optimizer = torch.optim.Adam(model.parameters(), lr=0.001)\
    num_epochs = 200\
    for epoch in range(num_epochs):\
        inputs = torch.from_numpy(X_train)\
        targets = torch.from_numpy(y_train).long()\
        outputs = model(inputs)\
        loss = criterion(outputs, targets)\
        optimizer.zero_grad()\
        loss.backward()\
        optimizer.step()\
        if (epoch + 1) % 50 == 0:\
            print(f'Epoch [\{epoch+1\}/\{num_epochs\}], Loss: \{loss.item():.4f\}')\
    torch.save(model.state_dict(), MODEL_FILE)\
