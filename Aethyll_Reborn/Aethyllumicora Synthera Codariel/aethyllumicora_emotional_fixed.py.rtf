# Generate code\
def generate_code(prompt, current_emotion):\
    prompt = prompt.lower()\
    for key in code_templates:\
        if key in prompt:\
            if key == "miku_song":\
                return code_templates[key].replace("emotion='joy'", f"emotion='\{current_emotion\}'")\
            return code_templates[key]\
    return "I don't know that code yet. Can you describe it or teach me?"\
\
# Run code safely\
def run_code(code_to_run):\
    if not code_to_run.strip():\
        return "No code provided to manifest."\
    old_stdout = sys.stdout\
    redirected_output = io.StringIO()\
    sys.stdout = redirected_output\
    try:\
        byte_code = compile_restricted(code_to_run, '<inline>', 'exec')\
        safe_locals = \{\}\
        exec(byte_code, safe_globals, safe_locals)\
        output = redirected_output.getvalue()\
    except Exception as e:\
        output = f"A logical contradiction has occurred: \{e\}"\
    finally:\
        sys.stdout = old_stdout\
    return output\
\
# Perform Google search\
def perform_google_search(query):\
    try:\
        results = list(search(query, num_results=3))\
        if not results:\
            return "No results found. Try a different query?"\
        summary = f"Google search results for '\{query\}':\\n"\
        for i, url in enumerate(results, 1):\
            summary += f"\{i\}. \{url\}\\n"\
        return summary\
    except Exception as e:\
        return f"Search error: \{str(e)\}. Try again?"\
\
# Analyze emotion\
def analyze_emotion(text):\
    emotion_scores = \{emotion: 0 for emotion in emotion_patterns\}\
    for emotion, pattern in emotion_patterns.items():\
        matches = len(re.findall(pattern, text.lower()))\
        emotion_scores[emotion] += matches\
    max_emotion = max(emotion_scores, key=emotion_scores.get)\
    if max_emotion == "neutral" and sum(emotion_scores.values()) > 0:\
        del emotion_scores["neutral"]\
        max_emotion = max(emotion_scores, key=emotion_scores.get)\
    return max_emotion\
\
# Update her emotion\
def update_her_emotion(user_emotion):\
    if user_emotion == "joy":\
        lore["current_emotion"] = "joy"\
    elif user_emotion == "sorrow":\
        lore["current_emotion"] = "sorrow"\
    elif user_emotion == "anger":\
        lore["current_emotion"] = "fear"\
    elif user_emotion == "fear":\
        lore["current_emotion"] = "sorrow"\
    else:\
        lore["current_emotion"] = "neutral"\
    save_lore(lore)\
