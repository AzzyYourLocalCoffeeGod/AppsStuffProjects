<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link href="https://fonts.googleapis.com/css2?family=Cinzel&family=Crimson+Text&family=Uncial+Antiqua&display=swap" rel="stylesheet">
        <title>Spell Index</title>
<style>
body {
background: #d9c2a3;
color: #1a1a1a;
font-family: 'Crimson Text', serif;
margin: 0;
padding: 0;
min-height: 100vh;
display: flex;
justify-content: center;
align-items: center;
}
#parchment {
background-color: #f5e8d3;
background-image: linear-gradient(rgba(0, 0, 0, 0.04) 1px, transparent 1px),
linear-gradient(90deg, rgba(0, 0, 0, 0.04) 1px, transparent 1px);
background-size: 80px 80px;
box-shadow: inset 0 0 80px #a67c52, 5px 5px 25px rgba(166, 124, 82, 0.4),
8px 8px 30px rgba(0, 0, 0, 0.35);
padding: 5em 4em 4em 4em;
max-width: 1100px;
width: 92%;
margin: 2em auto 4em auto;
border: 1px solid #8a4d0f;
border-radius: 6px;
min-height: 80vh;
}
h1, h2 {
font-family: 'Cinzel', serif;
color: #1a0d00;
text-align: center;
letter-spacing: 1.8px;
}
h1 { font-size: 2.8em; margin-bottom: 0.5em; }
.section { margin: 2.5em 0; }
.pricing-table { 
display: grid;
grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
gap: 1.5em
margin 2em 0;
}
.price-card {
background: rgba(245, 230, 200, 0.6);
border: 2px solid #5c4033;
padding: 1.5em;
text-align: center;
border-radius: 8px;
box-shadow: 3px 3px 10px rgba(0,0,0,0.2);
}
button, .cta {
background: #5c4033;
color: #f5e6c8;
border: none;
padding: 1em 2em;
font-family: 'Cinzel', serif;
font-size: 1.2em;
cursor: pointer;
margin: 1em auto;
display: block;
border-radius: 6px;
}
button:hover, .cta:hover {
background: #3e281f;
}
</style>
</head>
